# SerpApi — get your key at https://serpapi.com/manage-api-key
SERPAPI_API_KEY=your_serpapi_key_here

# Slack Incoming Webhook URL
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Vercel Blob — automatically provided when you link a Blob store
# (No manual setup needed — Vercel adds BLOB_READ_WRITE_TOKEN for you)

# Cron Secret — protects the endpoint from unauthorized calls
# Generate a random string (e.g. via: openssl rand -hex 16)
CRON_SECRET=your_random_secret_here
